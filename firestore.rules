rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'anph100387@gmail.com' && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Blueprint for BaziProfile
    function isValidBaziProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'gender', 'birthDate', 'pillars', 'dayMaster', 'strength', 'updatedAt']) &&
             data.keys().size() >= 8 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.gender in ['Nam', 'Nữ'] &&
             data.birthDate is string && data.birthDate.size() <= 50 &&
             data.dayMaster is string && data.dayMaster.size() <= 20 &&
             data.strength is string && data.strength.size() <= 60 &&
             data.pillars is map;
    }

    // Validation Blueprint for User Metadata
    function isValidUser(data) {
       return data.keys().hasAll(['credits']) &&
              data.credits is int && data.credits >= 0;
    }

    // Validation Blueprint for ChatMessage
    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'parts', 'timestamp', 'contextType']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.parts is list && data.parts.size() > 0 &&
             data.timestamp == request.time &&
             data.contextType in ['general', 'bazi'];
    }

    // Rules for Profiles
    match /profiles/{profileId} {
      allow get: if isOwner(profileId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      
      allow create: if isOwner(profileId) && 
                      isValidId(profileId) && 
                      isValidBaziProfile(incoming()) &&
                      incoming().userId == profileId;
                      
      allow update: if isOwner(profileId) && 
                      isValidBaziProfile(incoming()) &&
                      incoming().userId == existing().userId;
                      
      allow delete: if isOwner(profileId) || isAdmin();
    }

    // Rules for Chats
    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidChatMessage(incoming());
    }

    // Rules for User Metadata
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming());
                      
      allow update: if isOwner(userId) && 
                      (
                        // Action: Buy credits / Use credits / Set deviceId
                        incoming().diff(existing()).affectedKeys().hasAny(['credits', 'lastFreeUsed', 'deviceId'])
                      );
    }

    // Rules for Global Stats
    match /system/stats {
      allow get: if isSignedIn();
      allow write: if isSignedIn(); // Transactions will handle integrity
    }
  }
}
